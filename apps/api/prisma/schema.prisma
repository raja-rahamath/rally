generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// TENANT & CONFIGURATION
// ============================================================

model Tenant {
  id        String       @id @default(uuid())
  name      String
  slug      String       @unique
  industry  String
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  settings  TenantSetting[]
  branding  TenantBranding?
  users     User[]
  customers Customer[]
  points    PointsTransaction[]
  assets    Asset[]
  assetTypes AssetType[]
  transactions Transaction[]

  @@map("tenants")
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  TRIAL
}

model TenantSetting {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  key      String
  value    String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@map("tenant_settings")
}

model TenantBranding {
  id             String  @id @default(uuid())
  tenantId       String  @unique @map("tenant_id")
  logo           String?
  primaryColor   String  @default("#3B82F6") @map("primary_color")
  secondaryColor String  @default("#1E40AF") @map("secondary_color")
  appName        String  @map("app_name")
  favicon        String?
  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_branding")
}

// ============================================================
// USERS & AUTH (Admin/Staff)
// ============================================================

model User {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  email        String
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  role         UserRole @default(CSR)
  isActive     Boolean  @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  MANAGER
  CSR
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String?  @map("user_id")
  customerId String? @map("customer_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

// ============================================================
// CUSTOMERS
// ============================================================

model Customer {
  id            String         @id @default(uuid())
  tenantId      String         @map("tenant_id")
  phone         String
  countryCode   String         @map("country_code")
  firstName     String         @map("first_name")
  lastName      String         @map("last_name")
  email         String?
  nationalId    String?        @map("national_id")
  dateOfBirth   DateTime?      @map("date_of_birth")
  gender        Gender?
  language      String         @default("en")
  status        CustomerStatus @default(ACTIVE)
  pointsBalance Int            @default(0) @map("points_balance")
  tierLevel     String         @default("default") @map("tier_level")
  emailVerified Boolean        @default(false) @map("email_verified")
  emailVerifyCode String?      @map("email_verify_code")
  emailVerifyExpiry DateTime?  @map("email_verify_expiry")
  qrCode        String         @unique @map("qr_code")
  lastVisitAt   DateTime?      @map("last_visit_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  points        PointsTransaction[]
  assets        Asset[]
  transactions  Transaction[]

  @@unique([tenantId, phone, countryCode])
  @@map("customers")
}

enum Gender {
  MALE
  FEMALE
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

model OtpCode {
  id        String   @id @default(uuid())
  phone     String
  countryCode String @map("country_code")
  code      String
  expiresAt DateTime @map("expires_at")
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("otp_codes")
}

// ============================================================
// POINTS & TRANSACTIONS
// ============================================================

model PointsTransaction {
  id            String               @id @default(uuid())
  tenantId      String               @map("tenant_id")
  customerId    String               @map("customer_id")
  type          PointsTransactionType
  amount        Int
  balance       Int
  description   String
  referenceType String?              @map("reference_type")
  referenceId   String?              @map("reference_id")
  expiresAt     DateTime?            @map("expires_at")
  createdAt     DateTime             @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([tenantId, createdAt])
  @@map("points_transactions")
}

enum PointsTransactionType {
  EARN
  REDEEM
  EXPIRE
  ADJUST
  TRANSFER_IN
  TRANSFER_OUT
}

model PointsRule {
  id           String  @id @default(uuid())
  tenantId     String  @map("tenant_id")
  name         String
  pointsPerUnit Int    @map("points_per_unit")
  currency     String  @default("BHD")
  multiplier   Float   @default(1.0)
  conditions   Json?
  isActive     Boolean @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("points_rules")
}

// ============================================================
// TRANSACTIONS (Receipts/Invoices)
// ============================================================

model Transaction {
  id             String            @id @default(uuid())
  tenantId       String            @map("tenant_id")
  customerId     String            @map("customer_id")
  invoiceNumber  String?           @map("invoice_number")
  amount         Decimal           @db.Decimal(12, 3)
  currency       String            @default("BHD")
  date           DateTime
  status         TransactionStatus @default(PENDING)
  receiptImageUrl String?          @map("receipt_image_url")
  ocrData        Json?             @map("ocr_data")
  pointsEarned   Int?              @map("points_earned")
  reviewedBy     String?           @map("reviewed_by")
  reviewedAt     DateTime?         @map("reviewed_at")
  rejectionReason String?          @map("rejection_reason")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([customerId])
  @@map("transactions")
}

enum TransactionStatus {
  PENDING
  APPROVED
  REJECTED
  AUTO_APPROVED
}

// ============================================================
// ASSETS (Generic - Vehicle, Equipment, etc.)
// ============================================================

model AssetType {
  id               String                @id @default(uuid())
  tenantId         String                @map("tenant_id")
  name             String
  slug             String
  icon             String?
  fieldDefinitions Json                  @map("field_definitions")
  isActive         Boolean               @default(true) @map("is_active")
  createdAt        DateTime              @default(now()) @map("created_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assets Asset[]

  @@unique([tenantId, slug])
  @@map("asset_types")
}

model Asset {
  id          String      @id @default(uuid())
  tenantId    String      @map("tenant_id")
  customerId  String      @map("customer_id")
  assetTypeId String      @map("asset_type_id")
  name        String
  fields      Json
  status      AssetStatus @default(ACTIVE)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer  Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assetType AssetType @relation(fields: [assetTypeId], references: [id])
  services  ServiceRecord[]

  @@index([customerId])
  @@index([tenantId])
  @@map("assets")
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

model ServiceRecord {
  id          String   @id @default(uuid())
  assetId     String   @map("asset_id")
  tenantId    String   @map("tenant_id")
  serviceType String   @map("service_type")
  description String
  date        DateTime
  cost        Decimal? @db.Decimal(12, 3)
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("service_records")
}
