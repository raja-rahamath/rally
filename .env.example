# Database
DATABASE_URL="postgresql://rally:rally@localhost:5433/rally?schema=public"
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-in-production-refresh"
OTP_EXPIRY_MINUTES=5

# API
API_PORT=4000
API_PREFIX=/api/v1

# Admin Portal
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
ADMIN_PORT=3000

# Customer Portal
CUSTOMER_PORT=3001

# SMS Provider (configurable per tenant)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email
SENDGRID_API_KEY=
EMAIL_FROM=noreply@rally.app

# AI/LLM
AI_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Azure (OCR)
AZURE_FORM_RECOGNIZER_ENDPOINT=
AZURE_FORM_RECOGNIZER_KEY=

# Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
